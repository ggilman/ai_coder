#!/bin/bash
# ==============================================================================
# AI-CODER | Unified Launcher for Claude & OpenCode
# Author: George Gilman <ggilman@gmail.com>
# ==============================================================================
set -euo pipefail

ALIAS_NAME="ai"
PREF_FILE="$HOME/.ai-coder-pref"
FAMILY_PREF_FILE="$HOME/.ai-coder-family"
FAMILIES_DIR="$(dirname "$(realpath "$0")")/config/families"

# Load Core Library
CORE_SCRIPT="$(dirname "$(realpath "$0")")/libs/ai-coder-core.sh"
if [ ! -f "$CORE_SCRIPT" ]; then
    echo "Error: Core library not found at $CORE_SCRIPT" >&2
    exit 1
fi
source "$CORE_SCRIPT"

# Handle commands that don't require an agent selection
if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    cat <<HELP
Usage: $(basename "$0") [COMMAND]

Commands:
  spawn              Execute command in active workbench
  --status           Show GPU and engine status dashboard
  --setup            Create shell alias and configure proxy settings
  --clean            Stop and remove all containers
  --rebuild          Remove the workbench image to force a full rebuild
  --menu             Reset model family and tool preferences, show selection menus
  --gpu-mode         Reset GPU mode preference (single vs multi-GPU)
  --build-only       Build the workbench image then exit (no Hub or agent launch)
  --help             Show this message
HELP
    exit 0
fi

if [[ "${1:-}" == "--status" ]]; then
    exec "$(dirname "$(realpath "$0")")/ai-status.sh"
fi

if [[ "${1:-}" == "--clean" ]]; then
    teardown
    exit 0
fi

if [[ "${1:-}" == "--gpu-mode" ]]; then
    rm -f "$HOME/.ai-coder-gpuconf"
    echo -e "${CYAN}◈ GPU mode preference cleared. Run ${NC}${BOLD}./ai-coder --setup${NC}${CYAN} to reconfigure.${NC}"
    exit 0
fi

# Handle --setup: alias registration + proxy configuration
if [[ "${1:-}" == "--setup" ]]; then
    rc_file="$HOME/.bashrc"
    if [ "$IS_GITBASH" = "true" ]; then
        rc_file="$HOME/.bash_profile"
    elif [ "$SHELL" != "${SHELL%zsh}" ]; then
        rc_file="$HOME/.zshrc"
    fi

    echo -e "\n${CYAN}Shell alias — add '${ALIAS_NAME}' shortcut to $rc_file?${NC}"
    echo -e "${DIM}  Skip if you prefer to add ai-coder to your PATH manually.${NC}"
    echo -n "  Add alias? [Y/n]: "
    read -r _alias_input
    touch "$rc_file"
    sed -i.bak "/alias $ALIAS_NAME=/d" "$rc_file"
    case "${_alias_input,,}" in
        n|no)
            echo -e "${DIM}  Alias not added. Any previous alias has been removed from $rc_file.${NC}"
            ;;
        *)
            echo "alias $ALIAS_NAME='$(realpath "$0")'" >> "$rc_file"
            echo -e "${ICON_OK} Alias '${ALIAS_NAME}' added to $rc_file. Run: ${CYAN}source $rc_file${NC}"
            ;;
    esac

    echo -e "\n${CYAN}Proxy configuration (leave blank for none / to clear existing):${NC}"
    if [ -f "$HOME/.ai-coder-proxy" ]; then
        _cur_proxy=$(cat "$HOME/.ai-coder-proxy" 2>/dev/null || true)
        echo -e "${DIM}  Current proxy: ${_cur_proxy}${NC}"
    fi
    echo -n "  Proxy URL: "
    read -r _proxy_input
    if [ -n "$_proxy_input" ]; then
        echo "$_proxy_input" > "$HOME/.ai-coder-proxy"
        echo -e "${ICON_OK} Proxy saved: ${CYAN}${_proxy_input}${NC}"
    else
        rm -f "$HOME/.ai-coder-proxy"
        echo -e "${DIM}  No proxy set.${NC}"
    fi

    echo -e "\n${CYAN}Network isolation — block all internet access from containers?${NC}"
    echo -e "${DIM}  (Recommended for regulated environments. Leave blank to keep current setting.)${NC}"
    _cur_iso="no"
    if [ -f "$HOME/.ai-coder-netconfig" ]; then
        _cur_iso=$(grep '^isolated=' "$HOME/.ai-coder-netconfig" 2>/dev/null | cut -d= -f2- || echo "no")
    fi
    echo -e "${DIM}  Current: ${_cur_iso}${NC}"
    echo -n "  Isolate containers? [y/N]: "
    read -r _iso_input
    case "${_iso_input,,}" in
        y|yes)
            printf 'isolated=yes\n' > "$HOME/.ai-coder-netconfig"
            echo -e "${ICON_OK} Network isolation ${GREEN}enabled${NC}."
            ;;
        n|no)
            printf 'isolated=no\n' > "$HOME/.ai-coder-netconfig"
            echo -e "${DIM}  Network isolation disabled.${NC}"
            ;;
        *)
            echo -e "${DIM}  Network isolation unchanged (${_cur_iso}).${NC}"
            ;;
    esac

    # GPU mode — only prompt if multiple GPUs are detected
    _gpu_count=1
    _gpu_count=$($SMI --query-gpu=name --format=csv,noheader,nounits 2>/dev/null | grep -c '.' || echo 1)
    if [ "${_gpu_count:-1}" -gt 1 ]; then
        echo -e "\n${CYAN}GPU mode — ${_gpu_count} GPUs detected. Use all for inference?${NC}"
        _cur_gpu="multi"
        if [ -f "$HOME/.ai-coder-gpuconf" ]; then
            _cur_gpu=$(grep '^gpu_mode=' "$HOME/.ai-coder-gpuconf" 2>/dev/null | cut -d= -f2- || echo "multi")
        fi
        echo -e "${DIM}  Current: ${_cur_gpu}${NC}"
        echo -n "  Use all GPUs? [Y/n]: "
        read -r _gpu_input
        case "${_gpu_input,,}" in
            n|no)
                printf 'gpu_mode=single\n' > "$HOME/.ai-coder-gpuconf"
                echo -e "${DIM}  GPU mode set to single.${NC}"
                ;;
            *)
                printf 'gpu_mode=multi\n' > "$HOME/.ai-coder-gpuconf"
                echo -e "${ICON_OK} GPU mode set to ${GREEN}multi${NC}."
                ;;
        esac
    fi
    exit 0
fi

# --- [ PREFERENCE MANAGEMENT ] ------------------------------------------------

show_family_menu() {
    local pairs=()
    for f in "$FAMILIES_DIR"/*.conf; do
        [ -f "$f" ] || continue
        local name; name=$(grep -m1 '^MODEL_FAMILY=' "$f" | sed 's/^MODEL_FAMILY=//;s/"//g;s/\${[^:]*:-//;s/}//')
        [ -n "$name" ] || continue
        local key; key=$(basename "$f" .conf)
        pairs+=("$name:$key")
    done
    IFS=$'\n' pairs=($(printf '%s\n' "${pairs[@]}" | sort)); unset IFS

    while true; do
        echo -e "\n${CYAN}Please select your preferred model family:${NC}"
        local i=1
        for pair in "${pairs[@]}"; do
            echo "  $i) ${pair%%:*}"
            (( i++ ))
        done
        echo "  q) Quit"
        echo -n "Selection: "
        read -r choice
        if [[ "$choice" == "q" ]]; then exit 0; fi
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#pairs[@]} )); then
            local key="${pairs[$((choice-1))]#*:}"
            local name="${pairs[$((choice-1))]%%:*}"
            echo "$key" > "$FAMILY_PREF_FILE"
            echo -e "${ICON_OK} ${name} selected."
            return
        fi
        echo -e "${RED}Invalid selection.${NC}"
    done
}

show_menu() {
    local agents_dir
    agents_dir="$(dirname "$(realpath "$0")")/agents"

    local pairs=()
    for f in "$agents_dir"/ai-coder-*.sh; do
        [ -f "$f" ] || continue
        local name; name=$(grep -m1 '^TOOL_NAME=' "$f" | cut -d'"' -f2)
        [ -n "$name" ] || continue
        local key; key=$(basename "$f" .sh); key="${key#ai-coder-}"
        pairs+=("$name:$key")
    done
    IFS=$'\n' pairs=($(printf '%s\n' "${pairs[@]}" | sort)); unset IFS

    while true; do
        echo -e "\n${CYAN}Welcome to AI-Coder. Please select your preferred tool:${NC}"
        local i=1
        for pair in "${pairs[@]}"; do
            echo "$i) ${pair%%:*}"
            (( i++ ))
        done
        echo "q) Quit"
        echo -n "Selection: "
        read -r choice
        if [[ "$choice" == "q" ]]; then exit 0; fi
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#pairs[@]} )); then
            local key="${pairs[$((choice-1))]#*:}"
            local name="${pairs[$((choice-1))]%%:*}"
            echo "$key" > "$PREF_FILE"
            echo "$name selected."
            return
        fi
        echo -e "${RED}Invalid selection.${NC}"
    done
}

# --- [ MAIN ENTRY ] -----------------------------------------------------------

# Handle --menu flag: clears both family and tool preferences so both menus
# are shown again on the next step of this run.
if [[ "${1:-}" == "--menu" ]]; then
    rm -f "$FAMILY_PREF_FILE" "$PREF_FILE"
    shift
fi

# --- [ FAMILY SELECTION ] ----------------------------------------------------
# Show the family menu on first run or after --menu clears the preference.
if [ ! -f "$FAMILY_PREF_FILE" ] || [ -z "$(cat "$FAMILY_PREF_FILE" 2>/dev/null)" ]; then
    show_family_menu
fi

FAMILY_PREF=$(cat "$FAMILY_PREF_FILE")
FAMILY_CONF="$FAMILIES_DIR/${FAMILY_PREF}.conf"
if [ ! -f "$FAMILY_CONF" ]; then
    echo -e "${RED}Error: Unknown model family '${FAMILY_PREF}'. Run with --menu to reselect.${NC}"
    rm -f "$FAMILY_PREF_FILE"
    exit 1
fi
source "$FAMILY_CONF"

# --- [ TOOL SELECTION ] ------------------------------------------------------
# Show the tool menu on first run or after --menu clears the preference.
if [ ! -f "$PREF_FILE" ] || [ -z "$(cat "$PREF_FILE")" ]; then
    show_menu
fi

TOOL_PREF=$(cat "$PREF_FILE")

# Resolve child script from agents directory
AGENTS_DIR="$(dirname "$(realpath "$0")")/agents"
CHILD_SCRIPT="$AGENTS_DIR/ai-coder-${TOOL_PREF}.sh"
if [ ! -f "$CHILD_SCRIPT" ]; then
    echo -e "${RED}Error: Unknown tool '${TOOL_PREF}'. Run with --menu to reselect.${NC}"
    rm -f "$PREF_FILE"
    exit 1
fi
LOCAL_STACK_DIR="$(pwd)/.ai-coder/${TOOL_PREF}"

source "$CHILD_SCRIPT"

# Ensure local stack dir exists (needed before core logic starts using it)
mkdir -p "$MODEL_STORAGE_DIR" "$LOCAL_STACK_DIR"

# Set WORKBENCH variable
WORKBENCH="${WORKBENCH_PREFIX}-${PROJECT_ID}"

# Process commands
if [ "$#" -gt 0 ]; then
    handle_command "$@"
fi

# --- [ IGNITION ] -------------------------------------------------------------

check_docker || { echo -e "${RED}✘ Docker initialization failed${NC}"; exit 1; }
detect_model || true
download_model || {
    echo -e "${RED}✘ Model download failed${NC}"
    echo -e "${YELLOW}  If you are on a corporate or proxy network, run: ${CYAN}$(basename "$0") --setup${NC}"
    exit 1
}
if [ -z "${MODEL_FILE:-}" ]; then
    echo -e "${RED}✘ Model detection failed — no model available${NC}"; exit 1
fi
build_image || { echo -e "${RED}✘ Image build failed${NC}"; exit 1; }

if [ "${BUILD_ONLY:-false}" = "true" ]; then
    echo -e "${ICON_OK} Build complete — skipping Hub and workbench launch."
    exit 0
fi

ensure_git_identity
ensure_network_config
ensure_gpu_config
docker network create "$HUB_NETWORK" 2>/dev/null || true
if [ "${NETWORK_INTERNAL:-false}" = "true" ]; then
    docker network create --internal "$HUB_ISOLATED_NET" 2>/dev/null || true
fi

if [ -z "$(docker ps -q -f name=^/${GLOBAL_ENGINE_NAME}$ 2>/dev/null)" ]; then
    docker rm "$GLOBAL_ENGINE_NAME" "$GLOBAL_PROXY_NAME" 2>/dev/null || true
    start_hub_engine || { echo -e "${RED}✘ Hub startup failed${NC}"; exit 1; }
elif [ "${NEEDS_LITELLM_PROXY:-false}" = "true" ] && \
     [ -z "$(docker ps -q -f name=^/${GLOBAL_PROXY_NAME}$ 2>/dev/null)" ]; then
    # Engine is already up but proxy is missing (e.g. switched from a non-proxy
    # agent). Start just the proxy portion via start_hub_engine which is
    # idempotent for the engine (it will fail to recreate it but the proxy run
    # is what matters). Simpler: call start_hub_engine which stops+removes both
    # then restarts. Accept the brief engine restart cost.
    docker rm "$GLOBAL_ENGINE_NAME" "$GLOBAL_PROXY_NAME" 2>/dev/null || true
    start_hub_engine || { echo -e "${RED}✘ Hub startup failed${NC}"; exit 1; }
fi

apply_git_identity
configure_workbench

ensure_workbench_running || { echo -e "${RED}✘ Workbench startup failed${NC}"; exit 1; }

echo -ne "${CYAN}◈ Syncing VRAM Slots:${NC} "
retry_count=0
max_retries=300
engine_ready=false
proxy_ready=false

while [ "$retry_count" -lt "$max_retries" ]; do
    if docker exec "$GLOBAL_ENGINE_NAME" curl -s -m 2 http://localhost:8080/v1/models 2>/dev/null | grep -q '"id"'; then
        engine_ready=true
    fi

    if [ "${NEEDS_LITELLM_PROXY:-false}" = "true" ]; then
        if curl -s -m 2 http://localhost:4000/v1/models 2>/dev/null | grep -q '"object"'; then
            proxy_ready=true
        fi
    else
        proxy_ready=true
    fi

    if [ "$engine_ready" = "true" ] && [ "$proxy_ready" = "true" ]; then break; fi
    retry_count=$((retry_count + 1))
    echo -ne "◈"
    sleep 2
done

if [ "$engine_ready" = "true" ] && [ "$proxy_ready" = "true" ]; then
    echo -e " ${GREEN}READY${NC}"
else
    echo -e " ${RED}TIMEOUT${NC}"
    echo -e "${RED}✘ Engine/Proxy failed to initialize after $((retry_count * 2)) seconds${NC}"
    # Basic diagnostics
    _cid=$(docker ps -aq -f "name=$GLOBAL_ENGINE_NAME" 2>/dev/null) || true
    if [ -n "${_cid:-}" ]; then
        docker logs "$GLOBAL_ENGINE_NAME" 2>&1 | tail -20 | sed 's/^/    /'
    fi
    exit 1
fi

echo -e "${ICON_GEAR} Attaching to workbench..."
execute_tool

# --- [ POST-EXIT CLEANUP ] ----------------------------------------------------
echo -e "${CYAN}◈ Stopping workbench [$WORKBENCH]...${NC}"
docker stop "$WORKBENCH" 2>/dev/null || true
docker rm   "$WORKBENCH" 2>/dev/null || true

remaining_spokes=$(docker ps -q --filter "name=${WORKBENCH_PREFIX}-" 2>/dev/null | wc -l)
if [ "$remaining_spokes" -eq 0 ]; then
    stop_hub
else
    echo -e "${CYAN}◈ ${remaining_spokes} spoke(s) still running — Hub remains active.${NC}"
fi
