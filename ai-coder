#!/bin/bash
# ==============================================================================
# AI-CODER | Unified Launcher for Claude & OpenCode
# Author: George Gilman <ggilman@gmail.com>
# ==============================================================================
set -euo pipefail

source "$(dirname "$(realpath "$0")")/libs/fixpath.sh"
fixpath

ALIAS_NAME="ai"
FAMILIES_DIR="$(dirname "$(realpath "$0")")/config/families"

# Load Core Library
CORE_SCRIPT="$(dirname "$(realpath "$0")")/libs/ai-coder-core.sh"
if [ ! -f "$CORE_SCRIPT" ]; then
    echo "Error: Core library not found at $CORE_SCRIPT" >&2
    exit 1
fi
source "$CORE_SCRIPT"

# Load additional libraries
source "$(dirname "$(realpath "$0")")/libs/ai-coder-setup.sh"
source "$(dirname "$(realpath "$0")")/libs/ai-coder-menus.sh"

# Handle commands that don't require an agent selection
case "${1:-}" in
--help|-h)
    cat <<HELP
Usage: $(basename "$0") [COMMAND]

Commands:
  --status           Show GPU and engine status dashboard
  --setup            First-time and re-configuration wizard (alias, proxy, isolation, GPU, git)
  --update           Download and install the latest release from GitHub
  --fix-project      Fix line endings in the current project for AI editing (run from project folder)
  --clean            Stop and remove all containers
  --rebuild          Remove all workbench images to force a full rebuild on next run
  --menu             Reset model family, tool and Open WebUI preferences, show selection menus
  --build-only       Build the workbench image then exit (no Hub or agent launch)
  --help             Show this message
HELP
    exit 0 ;;
--update)
    cmd_update
    exit $? ;;
--status)
    exec "$(dirname "$(realpath "$0")")/ai-status.sh" ;;
--clean)
    check_docker || exit 1
    teardown
    exit 0 ;;
--fix-project)
    cmd_fix_project
    exit $? ;;
--setup)
    cmd_setup
    exit 0 ;;
esac

if [[ "${1:-}" == "--rebuild" ]]; then
    # Docker must be up ‚Äî with the daemon down every docker call below fails
    # silently and the .rebuild-needed flag would be cleared without rebuilding.
    check_docker || exit 1
    # Collect every image name defined in any agent script (current version).
    # tr -d '\r' guards against CRLF on Windows-mounted filesystems.
    # Also sweep for any leftover images from previous version numbers by
    # matching the naming convention patterns used across all agent generations.
    _agents_dir="$(dirname "$SCRIPT_DIR")/agents"
    _removed=0
    declare -A _seen_imgs=()
    for f in "$_agents_dir"/ai-coder-*.sh; do
        [ -f "$f" ] || continue
        _img=$(grep -m1 '^IMAGE_NAME=' "$f" | cut -d'"' -f2 | tr -d '\r')
        [ -z "$_img" ] && continue
        _seen_imgs["$_img"]=1
    done
    # Also include any Docker images whose name matches the historical naming
    # conventions: *-engineer-* and local-* (old naming from early versions).
    while IFS= read -r _img; do
        [ -n "$_img" ] && _seen_imgs["$_img"]=1
    done < <(docker images --format '{{.Repository}}' 2>/dev/null | grep -E '(-engineer-|^local-(claude|opencode|gemini|aider))' || true)
    for _img in "${!_seen_imgs[@]}"; do
        if docker image inspect "$_img" >/dev/null 2>&1; then
            echo -e "${CYAN}‚óà Removing [$_img]...${NC}"
            # Stop and remove any containers using this image before trying rmi.
            while IFS= read -r _cid; do
                [ -z "$_cid" ] && continue
                _cname=$(docker inspect --format '{{.Name}}' "$_cid" 2>/dev/null | tr -d '/')
                echo -e "${YELLOW}  Stopping container [${_cname:-$_cid}]...${NC}"
                docker stop "$_cid" 2>/dev/null || true
                docker rm   "$_cid" 2>/dev/null || true
            done < <(docker ps -aq --filter "ancestor=$_img" 2>/dev/null)
            if docker rmi "$_img" 2>/dev/null; then
                echo -e "${GREEN}‚úî Removed${NC}"
                _removed=$((_removed + 1))
            else
                echo -e "${YELLOW}  Could not remove [$_img]${NC}"
            fi
        fi
    done
    [ "$_removed" -eq 0 ] && \
        echo -e "${DIM}  No workbench images found ‚Äî nothing to remove.${NC}" || \
        echo -e "${ICON_OK} Workbench images cleared. They will be rebuilt on next run."
    rm -f "$USER_DIR/.rebuild-needed"
    exit 0
fi

# --- [ MAIN ENTRY ] -----------------------------------------------------------

# Guard: require --setup to have been run at least once before launching.
if [ ! -f "$USER_DIR/.setup-done" ]; then
    echo -e "${YELLOW}‚óà First-time setup required. Run:${NC}"
    echo -e "  ${CYAN}\"$(realpath "$0")\" --setup${NC}"
    exit 1
fi

if [ -f "$USER_DIR/.rebuild-needed" ]; then
    echo -e "${YELLOW}‚óà Git identity change detected.${NC}"
    echo -e "${DIM}  A rebuild is required to bake the new identity into your workbench images.${NC}"
    echo -e "  Run: ${CYAN}$(basename "$0") --rebuild${NC} then ${CYAN}$(basename "$0")${NC}"
    exit 1
fi

check_for_update

# Load optional user environment file ‚Äî a convenient place for secrets like
# API keys (e.g. BRAVE_API_KEY) that should be available for this session only
# and are not appropriate for your shell profile. Variables set here are
# available to all agent config generation (MCP servers, etc.).
# Resolves to the Windows home directory so the same file is shared between
# Git Bash and WSL (e.g. C:\Users\ggilm\.ai-coder-env).
AI_CODER_ENV_FILE="${AI_CODER_ENV_FILE:-$WIN_HOME/.ai-coder-env}"
if [ -f "$AI_CODER_ENV_FILE" ]; then
    # shellcheck source=/dev/null
    source "$AI_CODER_ENV_FILE"
fi

# Handle --menu flag: clears the family, tool, and Open WebUI preferences so
# all the selection questions are shown again on the next step of this run.
_prev_family=""; _prev_tool=""; _prev_webui=""
if [[ "${1:-}" == "--menu" ]]; then
    _prev_family=$(read_pref "$STATE_FILE" family_pref "")
    _prev_tool=$(read_pref   "$STATE_FILE" tool_pref   "")
    _prev_webui=$(read_pref  "$STATE_FILE" webui_pref  "")
    write_pref "$STATE_FILE" family_pref ""
    write_pref "$STATE_FILE" tool_pref   ""
    write_pref "$STATE_FILE" webui_pref  ""
    shift
fi

# --- [ FAMILY SELECTION ] ----------------------------------------------------
# Show the family menu on first run or after --menu clears the preference.
FAMILY_PREF=$(read_pref "$STATE_FILE" family_pref "")
if [ -z "$FAMILY_PREF" ]; then
    show_family_menu "$_prev_family"
    FAMILY_PREF=$(read_pref "$STATE_FILE" family_pref "")
fi

FAMILY_CONF="$FAMILIES_DIR/${FAMILY_PREF}.conf"
if [ ! -f "$FAMILY_CONF" ]; then
    echo -e "${RED}Error: Unknown model family '${FAMILY_PREF}'. Run with --menu to reselect.${NC}"
    write_pref "$STATE_FILE" family_pref ""
    exit 1
fi
source "$FAMILY_CONF"

# --- [ TOOL SELECTION ] ------------------------------------------------------
# Show the tool menu on first run or after --menu clears the preference.
TOOL_PREF=$(read_pref "$STATE_FILE" tool_pref "")
if [ -z "$TOOL_PREF" ]; then
    show_menu "$_prev_tool"
    TOOL_PREF=$(read_pref "$STATE_FILE" tool_pref "")
fi

# Resolve child script from agents directory
AGENTS_DIR="$(dirname "$(realpath "$0")")/agents"
CHILD_SCRIPT="$AGENTS_DIR/ai-coder-${TOOL_PREF}.sh"
if [ ! -f "$CHILD_SCRIPT" ]; then
    echo -e "${RED}Error: Unknown tool '${TOOL_PREF}'. Run with --menu to reselect.${NC}"
    write_pref "$STATE_FILE" tool_pref ""
    exit 1
fi

# --- [ OPEN WEBUI SIDECAR SELECTION ] -----------------------------------------
# Third question: offer to run Open WebUI alongside the coding agent. Only
# asked when the engine port is exposed to the host (enable via --setup), and
# skipped when Open WebUI itself is the selected tool. Left unanswered while
# the port is closed, so it appears automatically once exposure is enabled.
WEBUI_PREF=$(read_pref "$STATE_FILE" webui_pref "")
if [ -z "$WEBUI_PREF" ] && [ "$TOOL_PREF" != "webui" ] && \
   [ "$(read_pref "$SETTINGS_FILE" expose_host_port no)" = "yes" ]; then
    show_webui_prompt "$_prev_webui"
    WEBUI_PREF=$(read_pref "$STATE_FILE" webui_pref "")
fi

LOCAL_STACK_DIR="$(pwd)/.ai-coder/${TOOL_PREF}"

source "$CHILD_SCRIPT"

# Ensure local stack dir exists (needed before core logic starts using it)
mkdir -p "$MODEL_STORAGE_DIR"

# Set WORKBENCH variable. Includes the tool so switching tools (or two sessions
# with different tools in the same project) never reuses a container built from
# another agent's image.
WORKBENCH="${WORKBENCH_PREFIX}-${TOOL_PREF}-${PROJECT_ID}"

# --- [ CLEANUP TRAP ] --------------------------------------------------------
# Runs on normal exit, Ctrl-C (INT), and SIGTERM so containers are always
# stopped regardless of how the user exits.
_cleanup_done=false
_workbench_started=false
cleanup() {
    $_cleanup_done && return
    _cleanup_done=true
    trap - EXIT INT TERM
    # Only stop the workbench container if this process started it.
    # Guarding here prevents --build-only (or any early-exit path) from stopping
    # a workbench that belongs to a concurrently running session in the same project.
    if $_workbench_started; then
        echo -e "${CYAN}‚óà Stopping workbench [$WORKBENCH]...${NC}"
        docker stop "$WORKBENCH" 2>/dev/null || true
        docker rm   "$WORKBENCH" 2>/dev/null || true
    fi
    remaining_spokes=$(docker ps -q --filter "name=^/${WORKBENCH_PREFIX}-" 2>/dev/null | wc -l)
    if [ "$remaining_spokes" -eq 0 ]; then
        if [ "$(read_pref "$SETTINGS_FILE" keep_hub no)" = "yes" ]; then
            echo -e "${CYAN}‚óà Hub stays warm (keep-hub enabled) ‚Äî next session skips the model load.${NC}"
            _idle_min=$(read_pref "$SETTINGS_FILE" keep_hub_timeout 60)
            case "$_idle_min" in ''|*[!0-9]*) _idle_min=60 ;; esac
            if [ "$_idle_min" -gt 0 ]; then
                schedule_hub_idle_stop "$_idle_min"
                echo -e "${DIM}  Auto-stops after ${_idle_min} min idle; stop now with: $(basename "$0") --clean${NC}"
            else
                echo -e "${DIM}  Stop it manually with: $(basename "$0") --clean${NC}"
            fi
        else
            stop_hub
        fi
    else
        echo -e "${CYAN}‚óà ${remaining_spokes} spoke(s) still running ‚Äî Hub remains active.${NC}"
    fi
}
trap cleanup EXIT INT TERM

# Process commands
if [ "$#" -gt 0 ]; then
    handle_command "$@"
fi

# --- [ IGNITION ] -------------------------------------------------------------

check_docker || { echo -e "${RED}‚úò Docker initialization failed${NC}"; exit 1; }
# Mark the hub as in-use so any pending idle-stop watcher disarms.
write_pref "$STATE_FILE" hub_idle_since ""
# Surface (once) a thermal-guard trip from a previous run before starting again.
_guard_trip=$(read_pref "$STATE_FILE" engine_guard_trip "")
if [ -n "$_guard_trip" ]; then
    echo -e "${RED}‚öÝ The GPU thermal guard stopped the engine on a previous run:${NC}"
    echo -e "${RED}  ${_guard_trip}${NC}"
    echo -e "${YELLOW}  Check cooling/dust/airflow before another long run (threshold: MODEL_GPU_MAX_TEMP_C).${NC}"
    write_pref "$STATE_FILE" engine_guard_trip ""
fi
ensure_gpu_config
ensure_ctx_config
ensure_kv_config
detect_model || true
download_model || {
    echo -e "${RED}‚úò Model download failed${NC}"
    echo -e "${YELLOW}  If you are on a corporate or proxy network, run: ${CYAN}$(basename "$0") --setup${NC}"
    exit 1
}
if [ -z "${MODEL_FILE:-}" ]; then
    echo -e "${RED}‚úò Model detection failed ‚Äî no model available${NC}"; exit 1
fi
# Fetch the speculative-decoding draft model when enabled for this family.
# A failed draft download degrades gracefully to normal decoding.
if spec_decode_enabled; then
    download_draft_model || {
        echo -e "${YELLOW}‚öÝ Draft model unavailable ‚Äî speculative decoding disabled this session.${NC}"
        MODEL_DRAFT_FILE=""
    }
fi
ensure_git_identity
build_image || { echo -e "${RED}‚úò Image build failed${NC}"; exit 1; }

if [ "${BUILD_ONLY:-false}" = "true" ]; then
    echo -e "${ICON_OK} Build complete ‚Äî skipping Hub and workbench launch."
    exit 0
fi

ensure_container_gitconfig
ensure_network_config
docker network create "$HUB_NETWORK" 2>/dev/null || true
if [ "${NETWORK_INTERNAL:-false}" = "true" ]; then
    docker network create --internal "$HUB_ISOLATED_NET" 2>/dev/null || true
fi

_engine_running=false
[ -n "$(docker ps -q -f name=^/${GLOBAL_ENGINE_NAME}$ 2>/dev/null)" ] && _engine_running=true
_need_engine_restart=false

if $_engine_running; then
    # Restart if any engine-affecting setting changed since it was last started.
    _eng_gpu=$(read_pref    "$STATE_FILE" engine_gpu_mode "")
    _eng_model=$(read_pref  "$STATE_FILE" engine_model "")
    _eng_ctx=$(read_pref    "$STATE_FILE" engine_ctx "")
    _eng_kv=$(read_pref     "$STATE_FILE" engine_kv "")
    _eng_batch=$(read_pref  "$STATE_FILE" engine_batch "")
    _eng_expose=$(read_pref "$STATE_FILE" engine_expose "")
    _eng_net=$(read_pref    "$STATE_FILE" engine_net "")
    _eng_mvol=$(read_pref   "$STATE_FILE" engine_mvol "")
    _eng_spec=$(read_pref   "$STATE_FILE" engine_spec "")
    _cur_expose=$(read_pref "$SETTINGS_FILE" expose_host_port no)
    _cur_mvol=$(read_pref   "$SETTINGS_FILE" model_volume "$MODEL_VOLUME_DEFAULT")
    _cur_spec=no
    spec_decode_enabled && [ -f "$MODEL_STORAGE_DIR/${MODEL_DRAFT_FILE:-}" ] && _cur_spec=yes
    if [ -n "$_eng_gpu" ] && [ "$_eng_gpu" != "${GPU_MODE:-multi}" ]; then
        echo -e "${YELLOW}‚óà GPU mode changed (${_eng_gpu} ‚Üí ${GPU_MODE:-multi}) ‚Äî restarting engine...${NC}"
        _need_engine_restart=true
    elif [ -n "$_eng_model" ] && [ "$_eng_model" != "${MODEL_FILE:-}" ]; then
        echo -e "${YELLOW}‚óà Model changed (${_eng_model} ‚Üí ${MODEL_FILE:-}) ‚Äî restarting engine...${NC}"
        _need_engine_restart=true
    elif [ -n "$_eng_ctx" ] && [ "$_eng_ctx" != "${MODEL_CTX_SIZE:-}" ]; then
        echo -e "${YELLOW}‚óà Context size changed (${_eng_ctx} ‚Üí ${MODEL_CTX_SIZE:-}) ‚Äî restarting engine...${NC}"
        _need_engine_restart=true
    elif [ -n "$_eng_kv" ] && [ "$_eng_kv" != "$(kv_type_label)" ]; then
        echo -e "${YELLOW}‚óà KV cache type changed (${_eng_kv} ‚Üí $(kv_type_label)) ‚Äî restarting engine...${NC}"
        _need_engine_restart=true
    elif [ -n "$_eng_batch" ] && [ "$_eng_batch" != "${MODEL_BATCH_SIZE:-1024}/${MODEL_UBATCH_SIZE:-${MODEL_BATCH_SIZE:-1024}}" ]; then
        echo -e "${YELLOW}‚óà Batch size changed (${_eng_batch} ‚Üí ${MODEL_BATCH_SIZE:-1024}/${MODEL_UBATCH_SIZE:-${MODEL_BATCH_SIZE:-1024}}) ‚Äî restarting engine...${NC}"
        _need_engine_restart=true
    elif [ -n "$_eng_expose" ] && [ "$_eng_expose" != "$_cur_expose" ]; then
        echo -e "${YELLOW}‚óà Host port exposure changed (${_eng_expose} ‚Üí ${_cur_expose}) ‚Äî restarting engine...${NC}"
        _need_engine_restart=true
    elif [ -n "$_eng_net" ] && [ "$_eng_net" != "${NETWORK_INTERNAL:-false}" ]; then
        echo -e "${YELLOW}‚óà Network isolation changed (${_eng_net} ‚Üí ${NETWORK_INTERNAL:-false}) ‚Äî restarting engine...${NC}"
        _need_engine_restart=true
    elif [ -n "$_eng_mvol" ] && [ "$_eng_mvol" != "$_cur_mvol" ]; then
        echo -e "${YELLOW}‚óà Model storage mode changed (${_eng_mvol} ‚Üí ${_cur_mvol}) ‚Äî restarting engine...${NC}"
        _need_engine_restart=true
    elif [ -n "$_eng_spec" ] && [ "$_eng_spec" != "$_cur_spec" ]; then
        echo -e "${YELLOW}‚óà Speculative decoding changed (${_eng_spec} ‚Üí ${_cur_spec}) ‚Äî restarting engine...${NC}"
        _need_engine_restart=true
    fi
fi

if ! $_engine_running || $_need_engine_restart; then
    docker rm "$GLOBAL_ENGINE_NAME" "$GLOBAL_PROXY_NAME" 2>/dev/null || true
    start_hub_engine || { echo -e "${RED}‚úò Hub startup failed${NC}"; exit 1; }
elif [ "${NEEDS_LITELLM_PROXY:-false}" = "true" ] && \
     [ -z "$(docker ps -q -f name=^/${GLOBAL_PROXY_NAME}$ 2>/dev/null)" ]; then
    # Engine is already up but proxy is missing (e.g. switched from a non-proxy
    # agent). Restart both so the proxy gets a clean start alongside the engine.
    docker rm "$GLOBAL_ENGINE_NAME" "$GLOBAL_PROXY_NAME" 2>/dev/null || true
    start_hub_engine || { echo -e "${RED}‚úò Hub startup failed${NC}"; exit 1; }
fi

apply_git_identity
configure_workbench

ensure_workbench_running || { echo -e "${RED}‚úò Workbench startup failed${NC}"; exit 1; }
_workbench_started=$WORKBENCH_STARTED_BY_US

echo -ne "${CYAN}‚óà Syncing VRAM Slots:${NC} "
retry_count=0
max_retries=300
engine_ready=false
proxy_ready=false

while [ "$retry_count" -lt "$max_retries" ]; do
    # Bail early if the engine container has stopped (e.g. unsupported flag, missing model).
    # The engine runs with --restart no, so any exit means it won't come back.
    if ! docker ps -q -f "name=^/${GLOBAL_ENGINE_NAME}$" 2>/dev/null | grep -q .; then
        break
    fi
    # Fire both checks in parallel to avoid waiting serially
    docker exec "$GLOBAL_ENGINE_NAME" curl -s -m 2 http://localhost:8080/v1/models 2>/dev/null | grep -q '"id"' &
    _engine_pid=$!

    if [ "${NEEDS_LITELLM_PROXY:-false}" = "true" ]; then
        # Probe the proxy from inside the Docker network (via the engine
        # container) ‚Äî on the isolated internal network the proxy's published
        # port is not reachable from the host, so a host-side curl would
        # never succeed.
        docker exec "$GLOBAL_ENGINE_NAME" curl -s -m 2 "http://$GLOBAL_PROXY_NAME:4000/v1/models" 2>/dev/null | grep -q '"object"' &
        _proxy_pid=$!
        wait "$_engine_pid" && engine_ready=true
        wait "$_proxy_pid"  && proxy_ready=true
    else
        wait "$_engine_pid" && engine_ready=true
        proxy_ready=true
    fi

    if [ "$engine_ready" = "true" ] && [ "$proxy_ready" = "true" ]; then break; fi
    retry_count=$((retry_count + 1))
    echo -ne "‚óà"
    sleep 1
done

if [ "$engine_ready" = "true" ] && [ "$proxy_ready" = "true" ]; then
    echo -e " ${GREEN}READY${NC}"
    # llama.cpp can report ready while a GPU is silently oversubscribed
    # (WDDM pages the overflow to system RAM) ‚Äî check and warn before use.
    warn_if_vram_oversubscribed
else
    echo -e " ${RED}TIMEOUT${NC}"
    echo -e "${RED}‚úò Engine/Proxy failed to initialize after ~${retry_count} seconds${NC}"
    # Basic diagnostics
    _cid=$(docker ps -aq -f "name=$GLOBAL_ENGINE_NAME" 2>/dev/null) || true
    if [ -n "${_cid:-}" ]; then
        docker logs "$GLOBAL_ENGINE_NAME" 2>&1 | tail -20 | sed 's/^/    /'
    fi
    exit 1
fi

# Honour the Open WebUI sidecar choice now that the engine is ready. When the
# preference is anything but yes, make sure a leftover sidecar isn't running.
if [ "$TOOL_PREF" != "webui" ]; then
    if [ "${WEBUI_PREF:-}" = "yes" ]; then
        start_webui_sidecar
    else
        stop_webui_sidecar
    fi
fi

echo -e "${ICON_GEAR} Attaching to workbench..."
execute_tool
# Cleanup is handled by the EXIT trap (see above).
