# Normalize all text files to LF. Prevents CRLF in containers causing bash
# "syntax error near unexpected token" and Claude Code "Error editing file".
* text=auto eol=lf

# Explicitly binary — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.gz   binary
*.tar  binary
*.zip  binary
*.gguf binary
